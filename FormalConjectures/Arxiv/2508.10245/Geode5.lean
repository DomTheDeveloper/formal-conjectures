import FormalConjectures.Arxiv.«2508.10245».Geode5Defs
import FormalConjectures.Arxiv.«2508.10245».Geode5Proof.Complete

/-!
# The five-dimensional Geode challenge

*References:*
- [The Challenge of Computing Geode Numbers](https://arxiv.org/abs/2508.10245),
  by Tewodros Amdeberhan, Manuel Kauers, and Doron Zeilberger
- [Lattice Paths and the Geode](https://arxiv.org/abs/2507.09405), by Ira M. Gessel

Amdeberhan, Kauers, and Zeilberger ask for the exact value of the five-variable
Geode number `G(1000,1000,1000,1000,1000)`.
-/

namespace Arxiv.«2508.10245»

@[category test, AMS 5]
theorem geode5_diagonal_zero : geode5Diagonal 0 = 1 := by
  native_decide

@[category test, AMS 5]
theorem geode5_diagonal_one : geode5Diagonal 1 = 797698 := by
  native_decide

/-- The exact value of `G(1000,1000,1000,1000,1000)`. -/
@[category research solved, AMS 5]
theorem geode5_1000 : geode5Diagonal 1000 = answer() := by
  simpa [Geode5Proof.answerValue] using Geode5Proof.geode5_1000_complete

#print axioms geode5_1000

end Arxiv.«2508.10245»
